<div id="stories-modal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="storiesModalLabel" aria-hidden="true">
    <div class="modal-dialog stories-modal__dialog" role="document">
        <div class="modal-content stories-modal__content">
            <div class="modal-header stories-modal__header">
                <h5 class="stories-modal__title" id="storiesModalLabel">Создание истории</h5>
                <button type="button" class="stories-modal__close btn-close" data-action="close-modal" aria-label="Закрыть">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body stories-modal__body">
                <!-- Левая часть: предпросмотр и загрузка файла -->
                <div class="stories-editor__canvas">
                    <div class="stories-editor__dropzone">
                        <div class="stories-editor__dropzone-icon">
                            <i class="fa fa-upload" aria-hidden="true"></i>
                        </div>
                        <div class="stories-editor__dropzone-text">
                            Перетащите сюда фото или видео
                        </div>
                        <label class="stories-editor__file-btn">
                            <input type="file" class="stories-editor__file-input" data-action="select-file" accept="image/*,video/*" />
                        </label>
                    </div>
                    <div class="stories-editor__preview-container">
                        <img class="stories-editor__preview-image" alt="Preview">
                        <video class="stories-editor__preview-video" controls></video>
                    </div>
                </div>
                <!-- Правая часть: инструменты -->
                <div class="stories-editor__toolbar">
                    <button type="button" class="stories-editor__tool-btn stories-editor__tool-text" data-action="add-text">
                        <i class="fa fa-font me-2"></i>Текст
                    </button>
                    <button type="button" class="stories-editor__tool-btn stories-editor__tool-bg" data-action="set-bg">
                        <i class="fa fa-image me-2"></i>Фон
                    </button>
                    <div class="stories-editor__bg-panel">
                        <button type="button" class="stories-editor__bg-back">&larr;</button>
                        <div class="stories-editor__bg-title">Фон</div>
                        <div class="stories-editor__bg-label">Цвет</div>
                        <div class="stories-editor__bg-palette"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer stories-modal__footer">
                <div class="stories-editor__slides-panel" style="display:none;">
                    <div class="stories-editor__slides-list"></div>
                    <button type="button" class="stories-editor__slide-add">+</button>
                </div>
                <button type="button" class="stories-modal__publish-btn" data-action="publish-story">
                    Опубликовать
                </button>
            </div>
        </div>
    </div>
</div> 
