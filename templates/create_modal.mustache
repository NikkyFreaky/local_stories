<div id="stories-modal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="storiesModalLabel" data-form-type="system">
    <div class="modal-dialog stories-modal__dialog" role="document">
        <div class="modal-content stories-modal__content">
            <div class="modal-header stories-modal__header">
                <h5 class="stories-modal__title" id="storiesModalLabel">Создание истории</h5>
                <button type="button" class="stories-modal__close btn-close" data-action="close-modal" aria-label="Закрыть">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body stories-modal__body">
                <!-- Левая часть: предпросмотр и загрузка файла -->
                <div class="stories-editor__canvas">
                    <div class="stories-editor__dropzone">
                        <div class="stories-editor__dropzone-icon">
                            <i class="fa fa-upload" aria-hidden="true"></i>
                        </div>
                        <div class="stories-editor__dropzone-text">
                            Перетащите сюда фото или видео
                        </div>
                        <label class="stories-editor__file-btn">
                            <input type="file" class="stories-editor__file-input" data-action="select-file" accept="image/*,video/*" autocomplete="off" />
                        </label>
                    </div>
                    <div class="stories-editor__preview-container">
                        <img class="stories-editor__preview-image" alt="Preview">
                        <video class="stories-editor__preview-video" controls></video>
                    </div>
                </div>
                <!-- Правая часть: инструменты -->
                <div class="stories-editor__toolbar">
                    <button type="button" class="stories-editor__tool-btn stories-editor__tool-text" data-action="add-text">
                        <i class="fa fa-font me-2"></i>Текст
                    </button>
                    <button type="button" class="stories-editor__tool-btn stories-editor__tool-bg" data-action="set-bg">
                        <i class="fa fa-image me-2"></i>Фон
                    </button>
                    <div class="stories-editor__bg-panel">
                        <button type="button" class="stories-editor__bg-back">&larr;</button>
                        <div class="stories-editor__bg-title">Фон</div>
                        <div class="stories-editor__bg-label">Цвет</div>
                        <div class="stories-editor__bg-palette"></div>
                    </div>
                    <div class="stories-editor__text-panel">
                        <button type="button" class="stories-editor__text-back">&larr;</button>
                        <button type="button" class="stories-editor__text-add" data-action="add-text-block">+ Добавить текст</button>
                        <div class="stories-editor__text-controls">
                            <label>
                                Размер:
                                <select class="stories-editor__text-size" autocomplete="off">
                                    <option value="24">24</option>
                                    <option value="32" selected>32</option>
                                    <option value="40">40</option>
                                    <option value="48">48</option>
                                </select>
                            </label>
                            <div class="stories-editor__text-align">
                                <button type="button" data-align="left" title="Выровнять влево">⯇</button>
                                <button type="button" data-align="center" title="Выровнять по центру">≡</button>
                                <button type="button" data-align="right" title="Выровнять вправо">⯈</button>
                            </div>
                            <div class="stories-editor__text-colors">
                                <button type="button" data-color="#fff" style="background:#fff;"></button>
                                <button type="button" data-color="#000" style="background:#000;"></button>
                                <button type="button" data-color="#ff0000" style="background:#ff0000;"></button>
                                <button type="button" data-color="#ff9900" style="background:#ff9900;"></button>
                                <button type="button" data-color="#00ff00" style="background:#00ff00;"></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer stories-modal__footer">
                <div class="stories-editor__slides-panel" style="display:none;">
                    <div class="stories-editor__slides-list"></div>
                    <button type="button" class="stories-editor__slide-add">+</button>
                </div>
                <button type="button" class="stories-modal__publish-btn" data-action="publish-story">
                    Опубликовать
                </button>
            </div>
        </div>
    </div>
</div>
<!-- Кастомное модальное окно подтверждения -->
<div class="stories-confirm-modal" style="display:none;">
    <div class="stories-confirm-modal__overlay"></div>
    <div class="stories-confirm-modal__dialog">
        <div class="stories-confirm-modal__text"></div>
        <div class="stories-confirm-modal__actions">
            <button type="button" class="stories-confirm-modal__btn stories-confirm-modal__btn--ok">Да</button>
            <button type="button" class="stories-confirm-modal__btn stories-confirm-modal__btn--cancel">Нет</button>
        </div>
    </div>
</div> 
