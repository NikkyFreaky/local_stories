<div class="stories-nav" data-region="stories-nav">
    <!-- Кнопка создания истории -->
    <a href="#" class="stories-btn stories-create" data-action="open-stories-editor" aria-label="Создать историю">
        <i class="icon fa fa-plus" aria-hidden="true"></i>
    </a>
    <!-- Кнопки историй -->
    {{#stories}}
        <a href="#" class="stories-btn {{#seen}}stories-seen{{/seen}}{{^seen}}stories-unseen{{/seen}} me-2"
           data-action="open-story"
           data-story-id="{{id}}"
           aria-label="История {{id}}">
            <i class="icon fa fa-circle" aria-hidden="true"></i>
        </a>
    {{/stories}}
</div> 
